POSTGRES_USER=scribai
POSTGRES_PASSWORD=scribai
POSTGRES_DB=scribai
POSTGRES_PORT=5432

REDIS_PORT=6379

MINIO_ACCESS_KEY=scribai
MINIO_SECRET_KEY=scribaipass
MINIO_BUCKET=scribai-originals
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

API_PORT=8081
WEB_PORT=8080
WEB_API_URL=http://localhost:8081

OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_DEFAULT_MODEL=qwen2.5:7b-instruct
OLLAMA_VISION_MODEL=llama3.2-vision

TESSERACT_LANGS=spa+eng
SYNC_MAX_BYTES=2097152
MAX_UPLOAD_BYTES=52428800

# AES-256 master key para cifrar secretos en BD (Seq API key, etc).
# Genera con: openssl rand -base64 32
# OBLIGATORIO. Si falta, la API no arranca.
SCRIBAI_SECRETS_KEY=CHANGE_ME_base64_32_bytes
