{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "invoice_number",
    "issue_date",
    "supplier",
    "customer",
    "items",
    "totals"
  ],
  "properties": {
    "invoice_number": {
      "type": "string",
      "description": "Número de factura"
    },
    "issue_date": {
      "type": "string",
      "format": "date",
      "description": "Fecha emisión YYYY-MM-DD"
    },
    "due_date": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    },
    "currency": {
      "type": "string",
      "pattern": "^[A-Z]{3}$",
      "description": "ISO 4217, p.ej. EUR"
    },
    "supplier": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "tax_id": {
          "type": [
            "string",
            "null"
          ],
          "description": "CIF/NIF/VAT"
        },
        "address": {
          "type": [
            "string",
            "null"
          ]
        },
        "email": {
          "type": [
            "string",
            "null"
          ],
          "format": "email"
        },
        "phone": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "customer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "tax_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "address": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "description",
          "quantity",
          "unit_price",
          "line_total"
        ],
        "properties": {
          "description": {
            "type": "string"
          },
          "quantity": {
            "type": "number",
            "minimum": 0
          },
          "unit": {
            "type": [
              "string",
              "null"
            ]
          },
          "unit_price": {
            "type": "number"
          },
          "tax_rate": {
            "type": [
              "number",
              "null"
            ],
            "description": "IVA %, p.ej. 21"
          },
          "line_total": {
            "type": "number"
          }
        }
      }
    },
    "totals": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subtotal",
        "total"
      ],
      "properties": {
        "subtotal": {
          "type": "number"
        },
        "tax_total": {
          "type": [
            "number",
            "null"
          ]
        },
        "discount": {
          "type": [
            "number",
            "null"
          ]
        },
        "total": {
          "type": "number"
        }
      }
    },
    "payment_method": {
      "type": [
        "string",
        "null"
      ]
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}