{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "Host=postgres;Database=scribai;Username=scribai;Password=scribai"
  },
  "Ollama": {
    "BaseUrl": "http://host.docker.internal:11434",
    "DefaultModel": "qwen2.5:7b-instruct",
    "VisionModel": "llama3.2-vision",
    "TimeoutSeconds": 300,
    "Temperature": 0
  },
  "Storage": {
    "Endpoint": "minio:9000",
    "AccessKey": "scribai",
    "SecretKey": "scribaipass",
    "Bucket": "scribai-originals",
    "UseSsl": false
  },
  "Processing": {
    "SyncMaxBytes": 2097152,
    "MaxUploadBytes": 52428800,
    "TesseractLangs": "spa+eng",
    "TesseractDataPath": "./tessdata",
    "OcrConfidenceThreshold": 0.6,
    "WebhookMaxAttempts": 5
  },
  "Redis": {
    "ConnectionString": "redis:6379",
    "StreamKey": "scribai:extractions",
    "ConsumerGroup": "workers"
  },
  "Cors": {
    "Origins": [ "http://localhost:4200", "http://localhost:8080" ]
  }
}
